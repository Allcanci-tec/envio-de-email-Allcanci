# ⚠️ TEMPLATE - COPIE PARA .env E PREENCHA COM SUAS CREDENCIAIS
# NUNCA COMMITE O ARQUIVO .env - ELE ESTÁ NO .gitignore

# ===== BLING =====
BLING_CLIENT_ID=sua_client_id_aqui
BLING_CLIENT_SECRET=sua_client_secret_aqui
BLING_REDIRECT_URI=http://localhost:5000/callback
BLING_API_URL=https://api.bling.com.br/v3

# Bling Tokens
BLING_ACCESS_TOKEN=seu_token_bling_aqui
BLING_REFRESH_TOKEN=seu_refresh_token_bling_aqui

# Vercel API (para renovação automática)
VERCEL_API_TOKEN=seu_token_vercel_aqui
VERCEL_PROJECT_ID=seu_project_id_vercel_aqui

# ===== EMAIL =====
EMAIL_USUARIO=seu_email@dominio.com.br
EMAIL_SENHA=sua_senha_email_aqui
EMAIL_SMTP=smtp.seuservidor.com
EMAIL_PORTA=465

# ===== WONCA LABS API (SiteRastreio) =====
WONCA_API_KEY=sua_api_key_wonca_aqui
WONCA_API_URL=https://api-labs.wonca.com.br
WONCA_SERVICE_PATH=wonca.labs.v1.LabsService/Track

# ===== GITHUB PAGES =====
GITHUB_DOMAIN=seu-usuario.github.io
SITE_URL=https://seu-usuario.github.io/envio-de-email-Allcanci
